{
  "multipart": [
    { "when": { "facing": "north" }, "apply": { "model": "revivalages:block/drying_rack" } },
    { "when": { "facing": "east" }, "apply": { "model": "revivalages:block/drying_rack", "y": 90 } },
    { "when": { "facing": "south" }, "apply": { "model": "revivalages:block/drying_rack", "y": 180 } },
    { "when": { "facing": "west" }, "apply": { "model": "revivalages:block/drying_rack", "y": 270 } },
    { "when": { "stacked": "true", "facing": "north" }, "apply": { "model": "revivalages:block/drying_rack_stacked" } },
    { "when": { "stacked": "true", "facing": "east" }, "apply": { "model": "revivalages:block/drying_rack_stacked", "y": 90 } },
    { "when": { "stacked": "true", "facing": "south" }, "apply": { "model": "revivalages:block/drying_rack_stacked", "y": 180 } },
    { "when": { "stacked": "true", "facing": "west" }, "apply": { "model": "revivalages:block/drying_rack_stacked", "y": 270 } }
  ]
}
